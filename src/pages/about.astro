---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="About"
  description="About the person behind Wander Tiger."
  current="about"
>
  <section class="nes-container is-dark with-title">
    <p class="title">ABOUT</p>
    <div class="builder-hero">
      <img src="/brand/builder-pixel.png" alt="Pixel portrait of the builder" width="128" height="128" />
      <div>
        <h1 class="nes-text is-primary page-title hero-title">THE BUILDER</h1>
        <p class="nes-text hero-copy">
          I am a father of two young kids, based on a sunny island, documenting my
          journey in exploring AI and agentic AI.
        </p>
      </div>
    </div>
  </section>

  <section class="nes-container is-dark with-title section-gap">
    <p class="title">PROFILE</p>
    <div class="profile-grid">
      <div class="nes-container is-dark profile-tile">
        <p class="nes-text is-warning profile-label">HOME BASE</p>
        <p class="nes-text is-disabled profile-copy">Sunny island life, with two young kids keeping the real-world benchmark honest.</p>
      </div>
      <div class="nes-container is-dark profile-tile">
        <p class="nes-text is-warning profile-label">BACKGROUND</p>
        <p class="nes-text is-disabled profile-copy">Chartered Financial Analyst (CFA) with more than a decade in financial services.</p>
      </div>
      <div class="nes-container is-dark profile-tile">
        <p class="nes-text is-warning profile-label">MISSION</p>
        <p class="nes-text is-disabled profile-copy">Build, test, and document useful AI workflows instead of just reading about them.</p>
      </div>
    </div>
  </section>
</Layout>
