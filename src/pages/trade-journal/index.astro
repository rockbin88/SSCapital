---
import Layout from "../../layouts/Layout.astro";
import { getTrades } from "../../lib/trades";

const trades = getTrades();

const profitClass = (profit: string) => {
  if (profit === "—") return "";
  return profit.startsWith("(") ? "trade-loss" : "trade-profit";
};
---

<Layout
  title="Trade Journal"
  description="Trade journal and option desk notes from Wander Tiger."
  current="journal"
>
  <section class="nes-container is-dark with-title">
    <p class="title">TRADE JOURNAL</p>
    <h1 class="nes-text is-primary page-title hero-title">EXECUTED TRADES</h1>
    <p class="nes-text hero-copy">
      A structured log of trades executed by the option trading desk.
    </p>
  </section>

  <section class="nes-container is-dark with-title section-gap">
    <p class="title">TABLE</p>
    <div class="trade-table-wrap">
      <table class="nes-table is-bordered is-dark trade-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Ticker</th>
            <th>Strategy</th>
            <th>Qty</th>
            <th>Entry</th>
            <th>Exit</th>
            <th>Profit</th>
            <th>Executed by</th>
          </tr>
        </thead>
        <tbody>
          {trades.map((trade) => (
            <tr>
              <td data-label="#">{trade.id}</td>
              <td data-label="Ticker">{trade.ticker}</td>
              <td data-label="Strategy">{trade.strategy}</td>
              <td data-label="Qty">{trade.quantity}</td>
              <td data-label="Entry">{trade.entryPrice}</td>
              <td data-label="Exit">{trade.exitPrice}</td>
              <td data-label="Profit" class={profitClass(trade.profit)}>
                {trade.profit}
              </td>
              <td data-label="Executed by">{trade.executedBy}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
