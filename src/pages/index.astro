---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    title: "Option Trading Desk",
    status: "LIVE",
    badge: "is-success",
    href: "/option-trading-desk",
    description:
      "An agentic options desk for equity index and single-name option research, trade journaling, PnL tracking, and desk workflows.",
    stack: ["ASTRO", "AGENTS", "PNL", "JOURNAL"],
  },
  {
    title: "Personal Banker",
    status: "WIP",
    badge: "is-warning",
    href: "/personal-banker",
    description:
      "A personal finance and banking assistant concept. Placeholder for the next agentic AI project.",
    stack: ["PLANNED", "FINANCE", "ASSISTANT"],
  },
];
---

<Layout
  title="Home"
  description="Wander Tiger documents AI and agentic AI projects."
  current="home"
>
  <section class="hero-panel nes-container is-dark with-title">
    <p class="title">START</p>
    <div class="home-hero">
      <img src="/brand/wander-tiger-pixel.png" alt="Wander Tiger icon" width="128" height="128" />
      <div>
        <p class="nes-text is-disabled kicker">FIELD NOTES FROM A SUNNY ISLAND</p>
        <h1 class="wordmark wordmark-hero page-title">
          WANDER TIGER
        </h1>
        <p class="nes-text hero-copy">
          A documentary of my AI and agentic AI journey: experiments, tools, workflows,
          agents, mistakes, and useful things built along the way.
        </p>
      </div>
    </div>
  </section>

  <section class="nes-container is-dark with-title section-gap">
    <p class="title">PROJECTS</p>
    <div class="project-grid">
      {projects.map((project) => (
        <article class="project-card nes-container is-dark">
          <div class="project-card-head">
            <h2 class="nes-text is-warning project-title">{project.title}</h2>
            <span class="nes-badge"><span class={project.badge}>{project.status}</span></span>
          </div>
          <p class="nes-text is-disabled project-desc">{project.description}</p>
          <div class="tag-row">
            {project.stack.map((tag) => (
              <span class="mini-tag">{tag}</span>
            ))}
          </div>
          <a href={project.href} class="project-link">
            <button type="button" class="nes-btn is-primary">Open project →</button>
          </a>
        </article>
      ))}
    </div>
  </section>
</Layout>
