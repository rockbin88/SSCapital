---
interface Props {
  current: "home" | "about" | "optionDesk" | "personalBanker" | "journal" | "research";
}

const { current } = Astro.props;

const links = [
  { id: "home" as const, href: "/", label: "Home" },
  { id: "about" as const, href: "/about", label: "About" },
  { id: "optionDesk" as const, href: "/option-trading-desk", label: "Option Desk" },
  { id: "journal" as const, href: "/trade-journal", label: "Journal" },
];
---

<header class="site-header">
  <div class="nes-container is-dark">
    <a href="/" class="brand-link">
      <span>
        <p class="wordmark wordmark-small">WANDER TIGER</p>
        <p class="nes-text" style="margin: 0.25rem 0 0; font-size: 0.5rem;">AI JOURNEY LOG</p>
      </span>
    </a>
    <nav class="nav-links" aria-label="Main">
      {links.map((link) => (
        <a href={link.href} class:list={[{ "is-active": current === link.id }]}>
          <button type="button" class:list={["nes-btn", { "is-primary": current === link.id }]}>
            {link.label}
          </button>
        </a>
      ))}
    </nav>
  </div>
</header>
