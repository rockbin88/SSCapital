---
import "nes.css/css/nes.min.css";
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title: string;
  description?: string;
  current: "home" | "about" | "optionDesk" | "personalBanker" | "journal" | "research";
}

const {
  title,
  description = "Wander Tiger — a documentary of AI and agentic AI projects.",
  current,
} = Astro.props;

const pageTitle = title === "Home" ? "Wander Tiger | AI Journey Log" : `${title} | WANDER TIGER`;
---

<!doctype html>
<html lang="en" class="nes-pointer">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/brand/wander-tiger-pixel.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#212529" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/brand/wander-tiger-pixel.png" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/brand/wander-tiger-pixel.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p class="nes-text is-disabled">© {new Date().getFullYear()} WANDER TIGER · AI JOURNEY LOG</p>
    </footer>
  </body>
</html>
