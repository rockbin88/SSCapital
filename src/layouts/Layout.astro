---
import "nes.css/css/nes.min.css";
import "../styles/global.css";
import Nav from "../components/Nav.astro";

interface Props {
  title: string;
  description?: string;
  current: "home" | "projects" | "about" | "none";
  image?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Wander Tiger — a documentary of AI and agentic AI projects.",
  current,
  image = "/brand/wander-tiger-pixel.png",
  structuredData,
} = Astro.props;

const pageTitle = title === "Home" ? "Wander Tiger | AI Journey Log" : `${title} | WANDER TIGER`;
const siteUrl = Astro.site ?? new URL("https://sscapital.pages.dev");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const socialImage = new URL(image, siteUrl).toString();
const jsonLd = structuredData ? JSON.stringify(structuredData) : undefined;
---

<!doctype html>
<html lang="en" class="nes-pointer">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/brand/wander-tiger-pixel.png" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#111827" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Wander Tiger" />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap"
      rel="stylesheet"
    />
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <title>{pageTitle}</title>
  </head>
  <body>
    <Nav current={current} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <nav class="footer-links" aria-label="Footer">
        <a href="/journey">Journey</a>
        <a href="/resources">Resources</a>
        <a href="/disclaimer">Disclaimer</a>
        <a href="/privacy">Privacy</a>
      </nav>
      <p class="nes-text is-disabled">© {new Date().getFullYear()} WANDER TIGER · AI JOURNEY LOG</p>
    </footer>
  </body>
</html>
